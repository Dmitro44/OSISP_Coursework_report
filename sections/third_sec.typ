    ),
    [#emph("ID")], [16], [0], [Идентификатор транзакции для сопоставления запроса и ответа],
    [#emph("QR")], [1], [2], [Флаг типа сообщения: 0 -- запрос, 1 -- ответ],
    [#emph("Opcode")], [4], [2], [Тип операции: 0 -- стандартный запрос],
    [#emph("AA")], [1], [2], [Флаг авторитативного ответа],
    [#emph("TC")], [1], [2], [Флаг усечения сообщения],
    [#emph("RD")], [1], [2], [Флаг запроса рекурсии],
    [#emph("RA")], [1], [3], [Флаг доступности рекурсии на сервере],
    [#emph("Z")], [3], [3], [Зарезервированные биты, должны быть нулевыми],
    [#emph("RCODE")], [4], [3], [Код результата: 0 -- успех, 3 -- #emph("NXDOMAIN")],
    [#emph("QDCOUNT")], [16], [4], [Количество записей в секции запроса],
